# ═══════════════════════════════════════════════════════════════
# TonKiné au Travail — Variables d'environnement
# ═══════════════════════════════════════════════════════════════
# 1. Copiez ce fichier : cp .env.example .env
# 2. Remplissez TOUTES les valeurs marquées CHANGEZ_MOI
# 3. Ne committez JAMAIS le fichier .env dans git
# ═══════════════════════════════════════════════════════════════

# ── Base de données ──
DB_NAME=tonkine_db
DB_USER=tonkine_user
DB_PASSWORD=CHANGEZ_MOI_mot_de_passe_fort_ici
DB_ROOT_PASSWORD=CHANGEZ_MOI_root_password      # MySQL uniquement
DB_PORT=5432                                    # 5432 pour PG, 3306 pour MySQL

# ── JWT — OBLIGATOIRE en production ──
# Générez une clé sécurisée : openssl rand -hex 64
JWT_SECRET=CHANGEZ_MOI_minimum_64_caracteres_aleatoires_ici_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_EXPIRATION_MS=86400000   # 24 heures

# ── CORS — URLs frontend autorisées ──
# En production, mettez l'URL réelle de votre frontend
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Ports d'exposition ──
API_PORT=8080
FRONTEND_PORT=3000
